{
  "name": "capacitor",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/assets": "github:thaunknown/capacitor-assets",
    "@capacitor/browser": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/device": "^8.0.0",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/local-notifications": "^8.0.0",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/share": "8.0.1",
    "@capawesome-team/capacitor-android-foreground-service": "^8.0.0",
    "@types/webpack": "^5.28.5",
    "abslink": "^1.2.2",
    "bittorrent-tracker": "11.2.2",
    "capacitor-intent-uri": "^0.0.2",
    "capacitor-nodejs": "github:hayase-app/capacitor-nodejs",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^12.0.2",
    "cordova-plugin-pip": "^0.0.2",
    "cordova-res": "^0.15.4",
    "cross-env": "^10.1.0",
    "eslint-config-standard-universal": "^1.0.9",
    "native": "github:hayase-app/native",
    "node-fetch": "^3.3.2",
    "node-gyp-build-mobile": "^4.6.0-3",
    "nodejs-mobile-gyp": "^0.4.0",
    "npm-run-all": "^4.1.5",
    "torrent-client": "github:hayase-app/torrent-client",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-license-plugin": "^4.5.1"
  },
  "scripts": {
    "build:native": "docker build -f public/nodejs/Dockerfile -t nodejs-mobile-build . && docker run -v ${PWD}:/app/ -it nodejs-mobile-build:latest /bin/bash /app/public/nodejs/setup-deps.sh",
    "build:app": "cross-env NODE_ENV=production run-s build:web build:native build:assets",
    "build:web": "webpack build",
    "build:assets": "capacitor-assets generate --iconBackgroundColor #e5204c --iconBackgroundColorDark #e5204c --splashBackgroundColor #e5204c --splashBackgroundColorDark #e5204c --android",
    "dev:adb-port": "adb reverse tcp:5500 tcp:5500",
    "dev:ios": "run-p dev:start cap-run:ios",
    "dev:sync": "cap sync",
    "dev:android": "cap run android",
    "dev:android-port": "run-s dev:android dev:adb-port",
    "dev:start": "run-p dev:webpack dev:android-port",
    "dev:webpack": "webpack serve",
    "dev:logcat": "adb logcat -s \"NodeJS-Engine,nodejs,app.hayase,AppUpdater,Capacitor\"",
    "dev:logcat-enable": "adb shell setprop persist.log.tag VERBOSE",
    "dev:logcat-disable": "adb shell setprop persist.log.tag S",
    "test:e2e": "cross-env NODE_ENV=production run-s build:web dev:android"
  },
  "version": "6.4.32"
}